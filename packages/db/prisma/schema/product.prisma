model Product {
    id          Int             @id @default(autoincrement())
    code        String          @unique
    description String
    price       Float
    categoryId  Int
    category    ProductCategory @relation(fields: [categoryId], references: [id])
    stock       Int
    createdAt   DateTime        @default(now())
    updatedAt   DateTime        @updatedAt
}

model ProductCategory {
    id          Int       @id @default(autoincrement())
    code        String    @unique
    description String
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    products    Product[]
}
